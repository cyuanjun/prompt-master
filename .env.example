# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — https://platform.openai.com/api-keys
# Used for gpt-5.5 (target prompt generation + vision judging).
OPENAI_API_KEY=

# Optional: separate key for image generation (gpt-image-2). Used when you
# have a sponsor-provided / org-verified key just for images. If unset, image
# gen falls back to OPENAI_API_KEY.
OPENAI_IMAGE_API_KEY=

# Public app URL (used for OG tags, share links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo mode — when true, all API routes return fixture data and skip live AI calls.
# Flip to false once Supabase + OpenAI are wired and you're ready to spend credits.
NEXT_PUBLIC_DEMO_MODE=true
